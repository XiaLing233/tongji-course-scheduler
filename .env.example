# tongji-course-scheduler 配置模板
# cp .env.example .env 然后填入真实值

# === MySQL（必填，部署时必须修改密码，本地开发可以保持不动） ===
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_R_USER=readonly
DB_R_PASSWORD=your_readonly_password
DB_META=course_scheduler_meta

# === Redis（可保持不动） ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_STREAM_KEY=crawler:log
REDIS_STATUS_KEY=crawler:status
REDIS_MAXLEN=5000

# === 同济账号（爬虫登录 1.tongji.edu.cn，必填） ===
TJ_SNO=你的学号
TJ_PASSWD=你的密码

# === IMAP（加强认证验证码接收，可选） ===
IMAP_SERVER=imap.qq.com
IMAP_PORT=993
IMAP_EMAIL=your_qq_email@qq.com
IMAP_GRANTCODE=qq邮箱授权码

# === SMTP（同步完成/失败通知，可选） ===
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SENDER=notification_receiver@example.com
# AlertManager（Go）只支持 STARTTLS，需用 25/587 端口，不能用 465 implicit TLS
SMTP_ALERTMANAGER_PORT=25
CRAWLER_SEND_EMAIL=false

# === 应用 ===
APP_DEBUG=false
