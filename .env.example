# ============================================================
# .env.example — 同济课程调度器配置模板
# 使用方法: cp .env.example .env 然后填入真实值
# ============================================================

# === MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_R_USER=readonly
DB_R_PASSWORD=your_readonly_password
DB_META=course_scheduler_meta

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_STREAM_KEY=crawler:log
REDIS_STATUS_KEY=crawler:status
REDIS_MAXLEN=5000

# === 同济账号（爬虫登录 1.tongji.edu.cn） ===
TJ_SNO=你的学号
TJ_PASSWD=你的密码

# === IMAP（QQ邮箱验证码接收） ===
IMAP_SERVER=imap.qq.com
IMAP_PORT=993
IMAP_EMAIL=your_qq_email@qq.com
IMAP_GRANTCODE=qq邮箱授权码

# === SMTP（同步完成/失败通知） ===
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SENDER=notification_receiver@example.com
CRAWLER_SEND_EMAIL=false

# === 应用 ===
APP_DEBUG=false
