{
  "title": "API 总览",
  "uid": "xk-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 10,
      "type": "row",
      "title": "流量",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "请求速率",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_duration_seconds_count{path!=\"/api/health\"}[$__rate_interval])) by (method, path)",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      }
    },
    {
      "id": 2,
      "title": "错误率",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_duration_seconds_count{status=~\"5..\"}[$__rate_interval])) by (path) / sum(rate(flask_http_request_duration_seconds_count[$__rate_interval])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "排行",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "row",
      "title": "延迟与状态码",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 3,
      "title": "延迟 p50",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket{path!=\"/api/health\"}[$__rate_interval])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": false }
        }
      }
    },
    {
      "id": 4,
      "title": "延迟 p95",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket{path!=\"/api/health\"}[$__rate_interval])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": false }
        }
      }
    },
    {
      "id": 5,
      "title": "延迟 p99",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket{path!=\"/api/health\"}[$__rate_interval])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": false }
        }
      }
    },
    {
      "id": 6,
      "title": "状态码分布",
      "type": "piechart",
      "gridPos": { "x": 6, "y": 26, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "round(sum(increase(flask_http_request_duration_seconds_count{path!=\"/api/health\"}[$__range])) by (status))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "spanNulls": true }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 7,
      "title": "Top API",
      "type": "table",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "topk(8, round(sum(increase(flask_http_request_duration_seconds_count{path!=\"/api/health\"}[$__range])) by (path)))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "path" }, "properties": [{ "id": "displayName", "value": "端点" }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "请求数" }, { "id": "unit", "value": "short" }] }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "请求数", "desc": true }]
      }
    }
  ]
}
