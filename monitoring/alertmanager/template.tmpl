{{ define "email.custom.html" }}
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 24px; background: #f5f5f5; color: #333; }
  .card { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden; }
  .header { padding: 20px 24px; border-bottom: 1px solid #eee; }
  .header.critical { background: #fff5f5; border-left: 4px solid #e53e3e; }
  .header.warning { background: #fffaf0; border-left: 4px solid #dd6b20; }
  .header h2 { margin: 0; font-size: 18px; }
  .header.critical h2 { color: #c53030; }
  .header.warning h2 { color: #c05621; }
  .body { padding: 20px 24px; }
  .alert { margin-bottom: 16px; padding: 12px 16px; border-radius: 6px; background: #fafafa; border: 1px solid #eee; }
  .alert.firing { border-left: 3px solid #e53e3e; }
  .alert-label { font-size: 13px; color: #666; margin: 2px 0; }
  .alert-label strong { color: #333; }
  .summary { font-size: 15px; font-weight: 600; margin: 0 0 4px 0; }
  .description { font-size: 14px; color: #555; margin: 0; }
  .footer { padding: 16px 24px; border-top: 1px solid #eee; font-size: 12px; color: #999; text-align: center; }
  .footer a { color: #666; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; }
  .badge-critical { background: #fed7d7; color: #c53030; }
  .badge-warning { background: #feebc8; color: #c05621; }
</style>
</head>
<body>
<div class="card">
  <div class="header {{ if eq .CommonLabels.severity "critical" }}critical{{ else }}warning{{ end }}">
    <h2>
      <span class="badge {{ if eq .CommonLabels.severity "critical" }}badge-critical{{ else }}badge-warning{{ end }}">{{ .CommonLabels.severity | toUpper }}</span>
      &#8203;{{ .GroupLabels.alertname }}
    </h2>
    <p style="margin:4px 0 0;font-size:13px;color:#888">{{ .Alerts | len }} 条告警{{ if gt (len .Alerts) 1 }}（已聚合）{{ end }}</p>
  </div>
  <div class="body">
    {{ range .Alerts }}
    <div class="alert firing">
      <p class="summary">{{ .Annotations.summary }}</p>
      {{ if .Annotations.description }}<p class="description">{{ .Annotations.description }}</p>{{ end }}
      <div style="margin-top:8px">
        {{ range .Labels.SortedPairs }}
        <span class="alert-label"><strong>{{ .Name }}:</strong> {{ .Value }}</span>&nbsp;&nbsp;
        {{ end }}
      </div>
    </div>
    {{ end }}
  </div>
  <div class="footer">
    由 <a href="https://github.com/prometheus/alertmanager">Alertmanager</a> 发送 &middot;
    服务: {{ .CommonLabels.service }} &middot;
    {{ .Alerts | len }} 条告警
  </div>
</div>
</body>
</html>
{{ end }}
