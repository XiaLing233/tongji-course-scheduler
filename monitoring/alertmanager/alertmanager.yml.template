global:
  smtp_smarthost: '${SMTP_SERVER}:${SMTP_ALERTMANAGER_PORT}'
  smtp_from: '${SMTP_USERNAME}'
  smtp_auth_username: '${SMTP_USERNAME}'
  smtp_auth_password: '${SMTP_PASSWORD}'
  smtp_require_tls: true

route:
  receiver: email-admin
  group_by: ['alertname']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

receivers:
  - name: email-admin
    email_configs:
      - to: '${SMTP_SENDER}'
        headers:
          Subject: '[选课系统告警] {{ .GroupLabels.alertname }}'
